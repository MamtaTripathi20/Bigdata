# ── Database ────────────────────────────────────────────────────
POSTGRES_USER=music_user
POSTGRES_PASSWORD=music_pass
POSTGRES_DB=music_db
DATABASE_URL=postgresql+asyncpg://music_user:music_pass@postgres:5432/music_db

# ── Security ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=50579bb09b795b08cb0fd149f614c6c5cc1d8e69a0f4011b6bb99035a658fb48
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Local LLM (Ollama) ──────────────────────────────────────────
# Options for i5 CPU:
#   llama3.2:3b   → Fast, ~4GB RAM, good quality  ✅ Recommended
#   gemma2:2b     → Fastest, ~3GB RAM, decent quality
#   mistral:7b-q4 → Best quality, ~8GB RAM, slower
OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://localhost:11434

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
ANALYTICS_CACHE_TTL=1800     # 30 minutes
GENAI_CACHE_TTL=3600         # 1 hour

# ── App ─────────────────────────────────────────────────────────
ENVIRONMENT=development
# Change to: production
